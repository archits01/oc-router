# Change to your domain name
api.oc-router.com {
        # =========================================================================
	# Long-term static asset caching (high priority, placed first)
	# Files with hash can be cached permanently by both browser and CDN
	# =========================================================================
	@static {
		path /assets/*
		path /logo.png
		path /favicon.ico
	}
	header @static {
		Cache-Control "public, max-age=31536000, immutable"
		# Remove headers that may interfere with caching
		-Pragma
		-Expires
	}

	# =========================================================================
	# TLS Security Configuration
	# =========================================================================
	tls {
		# Use only TLS 1.2 and 1.3
		protocols tls1.2 tls1.3
		
		# Preferred cipher suites
		ciphers TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384 TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384 TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305_SHA256 TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305_SHA256 TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256 TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256
	}

	# =========================================================================
	# Reverse Proxy Configuration
	# =========================================================================
	reverse_proxy localhost:8080 {
		# Health check
		health_uri /health
		health_interval 30s
		health_timeout 10s
		health_status 200
		
		# Load balancing strategy (can be ignored for single node, useful for multi-node)
		lb_policy round_robin
		lb_try_duration 5s
		lb_try_interval 250ms
		
		# Pass real client information
		# Compatible with Cloudflare and direct connections: backend should read CF-Connecting-IP first, then X-Real-IP
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		# Preserve Cloudflare original headers (if present)
		# Recommended IP resolution priority for backend: CF-Connecting-IP -> X-Real-IP -> X-Forwarded-For
		header_up CF-Connecting-IP {http.request.header.CF-Connecting-IP}
		
		# Connection pool optimization
		transport http {
			keepalive 120s
			keepalive_idle_conns 256
			read_buffer 16KB
			write_buffer 16KB
			compression off
		}
		
		# Failover
		fail_duration 30s
		max_fails 3
		unhealthy_status 500 502 503 504
	}

	# =========================================================================
	# Compression Configuration
	# =========================================================================
	encode {
		zstd
		gzip 6
		minimum_length 256
		match {
			header Content-Type text/*
			header Content-Type application/json*
			header Content-Type application/javascript*
			header Content-Type application/xml*
			header Content-Type application/rss+xml*
			header Content-Type image/svg+xml*
		}
	}

	# =========================================================================
	# Request size limit (prevent large file attacks)
	# =========================================================================
	request_body {
		max_size 100MB
	}

	# =========================================================================
	# Log Configuration
	# =========================================================================
	log {
		output file /var/log/caddy/oc-router.log {
			roll_size 50mb
			roll_keep 10
			roll_keep_for 720h
		}
		format json
		level INFO
	}

	# =========================================================================
	# Error Handling
	# =========================================================================
	handle_errors {
		respond "{err.status_code} {err.status_text}"
	}
}
