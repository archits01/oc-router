[Unit]
Description=OC Router Data Management Daemon
After=network.target
Wants=network.target

[Service]
Type=simple
User=oc-router
Group=oc-router
WorkingDirectory=/opt/oc-router
ExecStart=/opt/oc-router/datamanagementd \
  -socket-path /tmp/oc-router-datamanagement.sock \
  -sqlite-path /var/lib/oc-router/datamanagement/datamanagementd.db \
  -version 1.0.0
Restart=always
RestartSec=5s
LimitNOFILE=100000
NoNewPrivileges=true
PrivateTmp=false

[Install]
WantedBy=multi-user.target
